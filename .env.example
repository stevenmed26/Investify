POSTGRES_DB=investify
POSTGRES_USER=investify
POSTGRES_PASSWORD=investify
POSTGRES_PORT=5432

API_PORT=8080
API_DB_HOST=postgres
API_DB_PORT=5432
API_DB_NAME=investify
API_DB_USER=investify
API_DB_PASSWORD=investify
API_ML_BASE_URL=http://ml-service:8000
ML_INTERNAL_TOKEN=dev-ml-internal-token

ML_PORT=8000

NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
INTERNAL_API_BASE_URL=http://api:8080
INTERNAL_ML_BASE_URL=http://ml-service:8000

MARKET_DATA_PROVIDER=twelvedata
TWELVE_DATA_BASE_URL=https://api.twelvedata.com

# System pipeline API key (used by daily scheduler, not per-user)
TWELVE_DATA_API_KEY=super-secret-api-key-for-twelve-data

# Optional override for ticker registry path (default: /app/data/tickers.json)
# TICKER_REGISTRY_PATH=./apps/data/tickers.json

JWT_SECRET=change-me-super-secret
APP_ENCRYPTION_KEY=change-me-super-secret-encryption-key
# APP_ENV=production

# Optional local-only admin seed. Store a bcrypt hash here, never plaintext.
DEV_ADMIN_EMAIL=admin@investify.com
# DEV_ADMIN_PASSWORD_HASH=$2a$10$replace-with-a-bcrypt-hash

NEXT_PUBLIC_DEV_TOOLS=true
# CORS: comma-separated list of allowed origins.
# In production set this to your actual frontend URL(s).
# Example: https://investify.example.com,https://www.investify.example.com
ALLOWED_ORIGINS=http://localhost:3000
